{
  "expo": {
    "name": "KalELConnect",
    "slug": "viralcut",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "viralcut",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kalel.KalelViralCut",
      "buildNumber": "3",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["instagram-reels", "instagram"],
        "NSContactsUsageDescription": "KalELConnect does not use your contacts. This permission is required by a third-party SDK included in the app."
      }
    },
    "android": {
      "package": "com.kalel.KalelViralCut",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#080a14"
      },
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "viralcut",
              "host": "tiktok-callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "viralcut",
              "host": "instagram-callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-media-library",
        {
          "photosPermission": "KalELConnect needs access to your photo library to save your edited video.",
          "savePhotosPermission": "KalELConnect needs permission to save your edited video before opening Instagram.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "KalELConnect needs access to your photo library to select videos for editing and publishing.",
          "cameraPermission": "KalELConnect needs access to your camera to record videos directly."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#080a14"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
